<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zone Dangereuse et Calculateur DVN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f0f4f8;
            overflow-x: hidden;
        }

        /* Styles for main scene and sections */
        .scene, .garage-scene-container {
            position: relative;
            width: 100%;
            height: 50vw;
            max-height: 400px;
            background-color: #585e58;
            overflow: hidden;
            border-radius: 10px;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
            display: flex;
            justify-content: center;
        }
        .rail {
            position: absolute;
            height: 100%;
            width: 2.2%;
            background-color: #444;
            top: 0;
            z-index: 1;
        }
        .rail.left { left: 45%; }
        .rail.right { left: 52.8%; }
        .dangerous-zone {
            position: absolute;
            top: 0;
            height: 100%;
            background-color: rgba(231, 76, 60, 0.2);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 2;
        }
        .danger-line {
            position: absolute;
            height: 100%;
            width: 0.8%;
            background-color: #e74c3c;
            animation: pulse-danger 1.5s infinite;
        }
        .danger-line.left { left: 0; }
        .danger-line.right { right: 0; }
        .safe-zone {
            position: absolute;
            top: 0;
            height: 100%;
            background-color: rgba(46, 204, 113, 0.2);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 2;
            animation: pulse-safe 1.5s infinite;
        }
        .safe-line {
            position: absolute;
            height: 100%;
            width: 0.8%;
            background-color: #2ecc71;
        }
        .safe-line.left { left: 0; }
        .safe-line.right { right: 0; }
        .train {
            position: absolute;
            width: 6.6%;
            height: 80%;
            background-color: #3498db;
            border-radius: 5px;
            box-shadow: 0 5px 10px rgba(0, 0, 0, 0.3);
            animation: moveTrain 3s linear infinite;
            z-index: 5;
        }
        .train.accotement-train {
            top: 100%;
            animation: moveTrain 4s linear infinite;
        }
        .train.entrevoie-train-left {
            top: -100%;
            animation: moveTrain 4s linear infinite;
        }
        .train.entrevoie-train-right {
            top: 100%;
            animation: moveTrain 4s linear infinite reverse;
        }
        .train-windows {
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            height: 90%;
            padding: 10% 0;
        }
        .train-window {
            width: 70%;
            height: 15%;
            background-color: #ecf0f1;
            border-radius: 3px;
            margin: 0 auto;
        }
        /* New styles for railroad ties */
        .traverses-container {
            position: absolute;
            left: 47.5%;
            top: 0;
            height: 100%;
            width: 5%;
            display: flex;
            flex-direction: column;
            justify-content: space-evenly;
            align-items: center;
            z-index: 0;
        }
        .traverse {
            width: 100%;
            height: 2%;
            background-color: #6d6d6d;
            border-radius: 2px;
        }

        /* Text and measurement styles */
        .danger-text, .safe-text, .zd-text, .garage-text {
            position: absolute;
            top: 10px;
            color: white;
            font-weight: bold;
            font-size: 0.9em;
            text-shadow: 0 0 5px black;
            z-index: 20;
            white-space: nowrap;
        }
        .danger-text {
            background-color: rgba(217, 83, 79, 0.8);
            padding: 5px 15px;
            border-radius: 5px;
            left: 50%;
            transform: translateX(-50%);
        }
        .safe-text {
            background-color: rgba(46, 204, 113, 0.8);
            padding: 5px 15px;
            border-radius: 5px;
        }
        .safe-text.left { left: auto; right: 50%; transform: translateX(50%); }
        .measurement-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(calc(-50% - 10px));
            height: 2px;
            background-color: white;
            z-index: 10;
            transition: width 0.5s, left 0.5s;
        }
        .measurement-arrow::before, .measurement-arrow::after {
            content: '';
            position: absolute;
            width: 0;
            height: 0;
            border-style: solid;
        }
        .measurement-arrow::before {
            left: 0;
            top: -4px;
            border-width: 6px 6px 6px 0;
            border-color: transparent white transparent transparent;
        }
        .measurement-arrow::after {
            right: 0;
            top: -4px;
            border-width: 6px 0 6px 6px;
            border-color: transparent transparent transparent white;
        }
        .measurement-arrow .measurement-text {
            position: absolute;
            top: -20px;
            color: white;
            white-space: nowrap;
            left: 50%;
            transform: translateX(-50%);
        }
        .d-text-container {
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
        }
        .d-text { color: white; font-weight: bold; }
        .zd-text, .garage-text { transform: translateX(-50%); }
        .zd-text .abbr-text { display: none; }
        .zd-text .full-text { display: inline; }
        /* Garage scheme specific styles */
        .garage-scene-container {
            background-color: transparent;
            box-shadow: none;
        }
        .garage-schema {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0; left: 0;
            background-color: #585e58;
            border-radius: 10px;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
            overflow: hidden;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.5s ease-in-out;
        }
        .garage-schema.active { opacity: 1; visibility: visible; }
        /* styles for the entrevoie schema */
        #garage-entrevoie-schema .dangerous-zone .danger-line {
            animation: none; /* Supprime l'animation */
        }
        #garage-entrevoie-schema .zd-text,
        #garage-entrevoie-schema .garage-text {
            font-size: 0.7em;
            padding: 2px 5px;
        }
        .sam-sign {
            background-color: red;
            color: white;
            font-weight: bold;
            padding: 8px 15px;
            border-radius: 5px;
            position: absolute;
            top: 50%;
            transform: translateY(-50%) translateX(-50%);
        }
        .voie-interdite-text-container {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            align-items: center;
            white-space: nowrap;
            right: 50px;
        }
        .voie-interdite-text-container .arrow {
            width: 30px;
            height: 2px;
            background-color: white;
            position: relative;
        }
        .voie-interdite-text-container .arrow::after {
            content: '';
            position: absolute;
            left: -6px; top: -4px;
            width: 0; height: 0;
            border-style: solid;
            border-width: 6px 6px 6px 0;
            border-color: transparent white transparent transparent;
        }
        /* Animations */
        @keyframes pulse-danger {
            0% { box-shadow: 0 0 5px 2px rgba(231, 76, 60, 0.5); }
            50% { box-shadow: 0 0 10px 4px rgba(231, 76, 60, 1); }
            100% { box-shadow: 0 0 5px 2px rgba(231, 76, 60, 0.5); }
        }
        @keyframes pulse-safe {
            0% { box-shadow: 0 0 5px 2px rgba(46, 204, 113, 0.5); }
            50% { box-shadow: 0 0 10px 4px rgba(46, 204, 113, 1); }
            100% { box-shadow: 0 0 5px 2px rgba(46, 204, 113, 0.5); }
        }
        @keyframes moveTrain {
            0% { top: 100%; }
            100% { top: -80%; }
        }
        /* Responsive design for smaller screens */
        @media (max-width: 768px) {
            .text-sm-center { text-align: center; }
            .zd-text .full-text { display: none; }
            .zd-text .abbr-text { display: inline; }
            .zd-text, .garage-text { font-size: 0.6em; }
            .danger-text, .safe-text { font-size: 0.7em; padding: 3px 8px; }
            .measurement-text { font-size: 0.6em; }
            .sam-sign {
                font-size: 0.5em;
                padding: 2px 4px;
            }
            .voie-interdite-text-container {
                right: 5%;
                font-size: 0.3em;
                color: white;
            }
            .voie-interdite-text-container .arrow {
                display: none;
            }
            .table-wrapper { overflow-x: hidden; }
            table, thead, tbody, th, td, tr { display: block; }
            thead tr { position: absolute; top: -9999px; left: -9999px; }
            tr { border: 1px solid #ccc; margin-bottom: 0.5rem; }
            td {
                border: none;
                border-bottom: 1px solid #eee; position: relative;
                padding-left: 50% !important; text-align: right;
            }
            td:before {
                position: absolute;
                top: 0.6em; left: 6px; width: 45%;
                padding-right: 10px; white-space: nowrap; text-align: left;
                font-weight: bold; color: #444;
            }
            td:nth-of-type(1):before { content: "Vitesse"; }
            td:nth-of-type(2):before { content: "0 < V ≤ 40"; }
            td:nth-of-type(3):before { content: "40 < V ≤ 160"; }
            td:nth-of-type(4):before { content: "160 < V ≤ 200"; }
            td:nth-of-type(5):before { content: "200 < V ≤ 300"; }
            td:nth-of-type(6):before { content: "300 < V ≤ 320"; }
            .flex.justify-center.space-x-4 button {
                padding: 0.5rem 1rem;
                font-size: 0.75rem;
            }
        }
        .table-wrapper .highlight {
            background-color: #f7967b !important;
            color: white !important;
        }
        .active-button {
            background-color: #2563eb;
            box-shadow: 0 0 0 3px #7FFF00; /* Electric green highlight */
        }
        .highlight-text {
            background-color: #FFFF00;
            padding: 2px 4px;
            border-radius: 4px;
        }
        /* Styles for the new "Dispositifs" section */
        .dispositifs-section h2 {
            font-weight: bold;
            color: #d9534f;
            margin-bottom: 1rem;
        }
        .dispositifs-section p, .dispositifs-section ul {
            margin-bottom: 1rem;
            color: #4b5563;
        }
        .dispositifs-section ul {
            list-style-type: none;
            padding-left: 1.5rem;
        }
        .dispositifs-section ul li {
            position: relative;
            padding-left: 1.5rem;
            margin-bottom: 0.5rem;
        }
        .dispositifs-section ul li:before {
            content: '';
            position: absolute;
            left: 0;
            top: 0.5rem;
            width: 8px;
            height: 8px;
            background-color: #d9534f;
            border-radius: 50%;
        }
        .dispositifs-section h3 {
            font-weight: bold;
            margin-top: 1rem;
            margin-bottom: 0.5rem;
        }
        .dispositifs-section .device-container {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        .dispositifs-section .device-item {
            background-color: #f7f7f7;
            border-left: 4px solid #d9534f;
            padding: 1rem;
            border-radius: 4px;
        }
        .dispositifs-section .alert-box {
            background-color: #fcebeb;
            border: 1px solid #d9534f;
            color: #d9534f;
            padding: 0.75rem;
            border-radius: 4px;
            text-align: center;
            font-weight: bold;
            margin-top: 1rem;
        }
        .dispositifs-section .device-content {
            display: flex;
            align-items: flex-start;
            gap: 1.5rem;
        }
    </style>
</head>
<body class="flex flex-col items-center justify-center min-h-screen p-4 bg-gray-100">
    <div class="container mx-auto p-6 bg-white rounded-xl shadow-lg w-full max-w-4xl">
        <h1 class="text-3xl font-bold text-center mb-6 text-gray-800">Zone Dangereuse et Calculateur DVN</h1>
        
        <h2 class="text-xl font-bold mb-2 text-gray-800 text-sm-center">ZONE DANGEREUSE</h2>
        <p class="text-center text-gray-600 mb-6 text-sm-center">
            <span class="highlight-text">Zone dangereuse (ZD)C’est la zone dans laquelle le personnel, ou l’outillage qu’il manipule, peut être heurté ou accroché par une circulation ferroviaire ou peut être mis en danger par l’effet de souffle.</span> Celle-ci se définit voie par voie.
        </p>
        
        <div class="table-wrapper overflow-x-hidden mb-6">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-red-500 text-white">
                        <th class="p-2 text-sm font-semibold">Vitesse en km/h</th>
                        <th class="p-2 text-sm font-semibold speed-header" data-speed="40" data-range="0 < V ≤ 40 km/h">0 &lt; V ≤ 40</th>
                        <th class="p-2 text-sm font-semibold speed-header" data-speed="160" data-range="40 < V ≤ 160 km/h">40 &lt; V ≤ 160</th>
                        <th class="p-2 text-sm font-semibold speed-header" data-speed="200" data-range="160 < V ≤ 200 km/h">160 &lt; V ≤ 200</th>
                        <th class="p-2 text-sm font-semibold speed-header" data-speed="300" data-range="200 < V ≤ 300 km/h">200 &lt; V ≤ 300</th>
                        <th class="p-2 text-sm font-semibold speed-header" data-speed="320" data-range="300 < V ≤ 320 km/h">300 &lt; V ≤ 320</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="bg-gray-100 text-gray-700">
                        <td class="p-2 text-sm font-medium">Distance (D)</td>
                        <td class="p-2 text-sm speed-cell" data-speed="40" data-range="0 < V ≤ 40 km/h">1,25 m</td>
                        <td class="p-2 text-sm speed-cell" data-speed="160" data-range="40 < V ≤ 160 km/h">1,50 m</td>
                        <td class="p-2 text-sm speed-cell" data-speed="200" data-range="160 < V ≤ 200 km/h">2,00 m</td>
                        <td class="p-2 text-sm speed-cell" data-speed="300" data-range="200 < V ≤ 300 km/h">2,00 m</td>
                        <td class="p-2 text-sm speed-cell" data-speed="320" data-range="300 < V ≤ 320 km/h">2,30 m</td>
                    </tr>
                </tbody>
            </table>
        </div>
     
        <div class="flex flex-col items-center mb-8">
            <label for="speed-slider" class="text-gray-700 font-bold mb-2 text-sm-center">Vitesse du train: <span id="speed-value" class="text-blue-600">0 &lt; V ≤ 40 km/h</span></label>
            <div class="flex items-center space-x-4 w-full max-w-lg">
                <input type="range" id="speed-slider" min="0" max="320" value="40" class="w-full h-2 bg-gray-300 rounded-lg appearance-none cursor-pointer">
                <div class="bg-gray-200 px-3 py-1 rounded-md font-bold"><span id="distance-value">1,25</span> m</div>
            </div>
        </div>
        <div class="scene mb-8">
            <div class="rail left"></div>
            <div class="rail right"></div>
            <div class="traverses-container"></div>
            <div class="dangerous-zone" id="dangerous-zone">
                <div class="danger-line left"></div>
                <div class="danger-line right"></div>
            </div>
            <div class="measurement-arrow" id="arrow-left">
                <span class="measurement-text"></span>
            </div>
            <div class="measurement-arrow" id="arrow-right">
                <span class="measurement-text"></span>
            </div>
            <div class="train">
                <div class="train-windows">
                    <div class="train-window"></div>
                    <div class="train-window"></div>
                    <div class="train-window"></div>
                </div>
            </div>
            <div class="danger-text">ZONE DANGEREUSE</div>
        </div>
        <hr class="my-6 border-gray-300">

        <h2 class="text-xl font-bold mb-2 text-gray-800 text-sm-center">Les emplacements de garage</h2>
        <p class="text-center text-gray-600 mb-2 text-sm-center">
            <span class="highlight-text">Un emplacement de garage est un lieu où le conducteur éventuellement avec le matériel ou l’outillage, peut se garer en dehors de toute zone dangereuse, lors du passage d’une circulation. Il peut être :</span>
        </p>
        <ul class="list-disc list-inside text-gray-600 mb-6 text-sm-center">
            <li>une piste aménagée le long des voies permettant de se déplacer ;</li>
            <li>un <span class="highlight-text">accotement</span> situé hors ZD ;</li>
            <li>une partie de quai hors de la zone dangereuse ;</li>
            <li>une <span class="highlight-text">voie interdite à la circulation</span> et non parcourue, en dehors du chantier, par des trains de travaux ;</li>
            <li>une <span class="highlight-text">niche</span> ;</li>
            <li>un <span class="highlight-text">refuge d’ouvrage d’art</span> ;</li>
            <li>une <span class="highlight-text">entrevoie large</span> ; dans ce cas les limites des zones d’entrevoie permettant le garage peuvent être repérées sur le terrain par un pancartage.</li>
        </ul>
        <p class="text-center text-gray-600 mb-6 text-sm-center">Sa largeur minimale est de 0,70 m.</p>
        
        <p class="text-center font-bold text-gray-800 mb-4">Exemples d’emplacements de garage : </p>

        <div class="flex justify-center space-x-4 mb-8">
            <button id="garage-accotement" class="px-6 py-2 bg-blue-500 text-white rounded-full font-semibold hover:bg-blue-600 focus:outline-none transition-transform transform hover:scale-105 active-button">Accotement</button>
            <button id="garage-entrevoie" class="px-6 py-2 bg-blue-500 text-white rounded-full font-semibold hover:bg-blue-600 focus:outline-none transition-transform transform hover:scale-105">Entrevoie Large</button>
            <button id="garage-voie-interdite" class="px-6 py-2 bg-blue-500 text-white rounded-full font-semibold hover:bg-blue-600 focus:outline-none transition-transform transform hover:scale-105">Voie Interdite</button>
        </div>

        <div class="garage-scene-container">
            <div id="garage-accotement-schema" class="garage-schema active">
                <div class="rail left"></div>
                <div class="rail right"></div>
                <div class="traverses-container"></div>
                <div class="dangerous-zone" id="accotement-dangerous-zone">
                    <div class="danger-line left"></div>
                    <div class="danger-line right"></div>
                </div>
                <div class="safe-zone" id="accotement-garage-zone-left">
                    <div class="safe-line left"></div>
                    <div class="safe-line right"></div>
                </div>
                <div class="safe-zone" id="accotement-garage-zone-right">
                    <div class="safe-line left"></div>
                    <div class="safe-line right"></div>
                </div>
                <div class="measurement-arrow" id="accotement-danger-arrow-left">
                    <div class="d-text-container"><span class="d-text">D</span></div>
                </div>
                <div class="measurement-arrow" id="accotement-danger-arrow-right">
                    <div class="d-text-container"><span class="d-text">D</span></div>
                </div>
                <div class="measurement-arrow" id="accotement-garage-arrow-left">
                    <span class="measurement-text">0,70 m</span>
                </div>
                <div class="measurement-arrow" id="accotement-garage-arrow-right">
                    <span class="measurement-text">0,70 m</span>
                </div>
                <div class="train accotement-train" id="accotement-train">
                    <div class="train-windows">
                        <div class="train-window"></div>
                        <div class="train-window"></div>
                        <div class="train-window"></div>
                    </div>
                </div>
                <div class="zd-text" id="accotement-zd-text"><span class="full-text">ZONE DANGEREUSE</span><span class="abbr-text">ZD</span></div>
                <div class="garage-text" id="garage-text-left">GARAGE</div>
                <div class="garage-text" id="garage-text-right">GARAGE</div>
            </div>
            <div id="garage-entrevoie-schema" class="garage-schema">
                </div>
            <div id="garage-voie-interdite-schema" class="garage-schema"></div>
        </div>
        
        <hr class="my-6 border-gray-300">

        <div class="dispositifs-section">
            <h2 class="text-xl font-bold mb-4 text-gray-800">Les dispositifs d’engagement de la zone dangereuse</h2>
            <p class="text-gray-600">Le déplacement le long des voies peut nécessiter l’engagement de la zone dangereuse pour le contournement d’un ouvrage ou d’un obstacle. De même, la traversée de voies peut être la seule possibilité pour assurer la continuité du déplacement. Pour répondre à ces besoins, deux dispositifs sont susceptibles d’être utilisés dans les lieux qui le nécessitent :</p>
            <div class="device-container">
                <div class="device-item">
                    <h3>- <span class="highlight-text">le DATZD : Dispositif d’Autorisation de Traversée de la Zone Dangereuse.</span></h3>
                    <p>Il permet la traversée d’une ou de deux voies lorsque la visibilité ou la réglementation ne le permet pas. Il est associé à une consigne d’utilisation.</p>
                    <div class="device-content">
                        <ul>
                            <li>Un DATZD comporte :</li>
                            <ul>
                                <li>un feu vert par voie ;</li>
                                <li>un bouton-poussoir installé de chaque côté de la ou des voies à traverser ;</li>
                                <li>une plaque de prescription d’emploi située hors zone dangereuse.</li>
                            </ul>
                        </ul>
                    </div>
                    <div class="alert-box">
                        Pour utiliser ce dispositif, le conducteur doit être formé à son utilisation.
                    </div>
                </div>
                <div class="device-item">
                    <h3>- <span class="highlight-text">le DAELZD : Dispositif d’Autorisation d’Engagement Longitudinal de la Zone Dangereuse</span> (pour le personnel).</h3>
                    <p>Il permet l’engagement de la ZD de la voie longeant un obstacle dont le franchissement est impossible du fait d’une visibilité insuffisante.</p>
                    <div class="device-content">
                        <ul>
                            <li>Un DAELZD comporte :</li>
                            <ul>
                                <li>un voyant vert ;</li>
                                <li>un bouton-poussoir ;</li>
                                <li>une plaque prescription d’emploi située hors zone dangereuse.</li>
                            </ul>
                        </ul>
                    </div>
                    <div class="alert-box">
                        Pour utiliser ce dispositif, le conducteur doit être formé à son utilisation.
                    </div>
                </div>
            </div>
        </div>
        
        <hr class="my-6 border-gray-300">

        <h2 class="text-xl font-bold mb-4 text-gray-800 text-sm-center">Calculateur de DVN</h2>
        <div class="flex flex-col md:flex-row items-center md:items-start justify-center md:space-x-8 mb-6">
            <div class="flex flex-col md:items-start items-center mb-4 md:mb-0">
                <label for="action-select" class="text-gray-700 font-bold mb-2 text-sm-center">Délai de visibilité nécessaire</label>
                <select id="action-select" class="px-4 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="4" data-short-text="10 secondes" data-full-text="10 seconde traverser 1-2 voies ou obstacle continue jusqu 'a 5 metre ">10 secondes</option>
                    <option value="6" data-short-text="15 secondes" data-full-text="15 seconde traverser 3-4 voies ou obstacle continue 5-10 mètre ">15 secondes</option>
                    <option value="8" data-short-text="20 secondes" data-full-text="20 seconde traverser 5-6 voies ou obstacle continue 10-15 mètre ">20 secondes</option>
                </select>
            </div>
            <div class="flex flex-col md:items-start items-center">
                <label for="speed-select" class="text-gray-700 font-bold mb-2 text-sm-center">Vitesse (Vmax)</label>
                <select id="speed-select" class="px-4 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="30">Jusqu'à 30 km/h</option>
                    <option value="40">Entre 31 et 40 km/h</option>
                    <option value="60">Entre 41 et 60 km/h</option>
                    <option value="120">Entre 61 et 120 km/h</option>
                    <option value="160">Entre 121 et 160 km/h</option>
                </select>
            </div>
        </div>
        <div class="text-center font-bold text-xl text-blue-600 mb-6 text-sm-center">
            DVN : <span id="dvn-result"></span>
        </div>
    </div>
    
    <div class="text-center text-gray-500 text-sm mt-4">
        Développer par Zaber MOHAMMAD 
    </div>

    <script>
        // DOM elements
        const speedSlider = document.getElementById('speed-slider');
        const speedValue = document.getElementById('speed-value');
        const distanceValue = document.getElementById('distance-value');
        const dangerousZone = document.getElementById('dangerous-zone');
        const train = document.querySelector('.train');
        const arrowLeft = document.getElementById('arrow-left');
        const arrowRight = document.getElementById('arrow-right');
        const garageSchemaElements = document.querySelectorAll('.garage-schema');
        const garageAccotementBtn = document.getElementById('garage-accotement');
        const garageEntrevoieBtn = document.getElementById('garage-entrevoie');
        const garageVoieInterditeBtn = document.getElementById('garage-voie-interdite');
        const garageButtons = document.querySelectorAll('.flex.justify-center.space-x-4 button');
        const actionSelect = document.getElementById('action-select');
        const speedSelect = document.getElementById('speed-select');
        const dvnResult = document.getElementById('dvn-result');
        const speedHeaders = document.querySelectorAll('.speed-header');
        const speedCells = document.querySelectorAll('.speed-cell');

        const dvnData = {
            '4': { 30: 90, 40: 120, 60: 170, 120: 340, 160: 450 },
            '6': { 30: 130, 40: 170, 60: 250, 120: 500, 160: 670 },
            '8': { 30: 170, 40: 230, 60: 340, 120: 670, 160: 890 },
        };
        const distances = [
            { speed: 40, distance: 1.25, range: '0 < V ≤ 40 km/h' },
            { speed: 160, distance: 1.50, range: '40 < V ≤ 160 km/h' },
            { speed: 200, distance: 2.00, range: '160 < V ≤ 200 km/h' },
            { speed: 300, distance: 2.00, range: '200 < V ≤ 300 km/h' },
            { speed: 320, distance: 2.30, range: '300 < V ≤ 320 km/h' }
        ];
        let zoneDistance = 1.25;

        function updateDVN() {
            const actionTime = actionSelect.value;
            const speed = speedSelect.value;
            const dvn = dvnData[actionTime][speed];
            dvnResult.textContent = `${dvn} mètres`;
        }
        
        function createTraverses(container, numTraverses = 25) {
            container.innerHTML = '';
            for (let i = 0; i < numTraverses; i++) {
                const traverse = document.createElement('div');
                traverse.className = 'traverse';
                container.appendChild(traverse);
            }
        }

        function updateZoneWidth(speed) {
            const distanceObj = distances.find(d => speed <= d.speed) || distances[distances.length - 1];
            zoneDistance = distanceObj.distance;
            const formattedDistance = zoneDistance.toFixed(2).replace('.', ',');
            if (distanceValue) {
                distanceValue.textContent = formattedDistance;
            }
            const scene = document.querySelector('.scene');
            if (!scene) return;
            const sceneWidth = scene.offsetWidth;
            const railWidth = sceneWidth * 0.022;
            const trackWidth = sceneWidth * 0.078;
            const minVisualDistance = 0.22 * sceneWidth;
            const maxVisualDistance = 0.35 * sceneWidth;
            const minDistance = 1.25;
            const maxDistance = 2.30;
            const visualDistance = minVisualDistance + ((zoneDistance - minDistance) / (maxDistance - minDistance)) * (maxVisualDistance - minVisualDistance);
            const totalWidth = trackWidth + (2 * visualDistance);
            if (dangerousZone) {
                dangerousZone.style.width = `${totalWidth}px`;
                dangerousZone.style.left = `calc(50% - ${totalWidth / 2}px)`;
            }
            if (train) {
                if (speed === 0) {
                    train.style.animationPlayState = 'paused';
                } else {
                    const minAnimationDuration = 1.5;
                    const maxAnimationDuration = 6;
                    const animationDuration = maxAnimationDuration - (speed / 320) * (maxAnimationDuration - minAnimationDuration);
                    train.style.animationDuration = `${animationDuration}s`;
                    train.style.animationPlayState = 'running';
                }
            }
            const railLeftPositionPx = sceneWidth * 0.45;
            const railRightPositionPx = sceneWidth * 0.528;
            const dangerousZoneLeftPx = (sceneWidth / 2) - (totalWidth / 2);
            const dangerousZoneRightPx = (sceneWidth / 2) + (totalWidth / 2);
            if (arrowLeft) {
                arrowLeft.style.width = `${railLeftPositionPx - dangerousZoneLeftPx}px`;
                arrowLeft.style.left = `${dangerousZoneLeftPx}px`;
                arrowLeft.querySelector('.measurement-text').textContent = formattedDistance + ' m';
            }
            if (arrowRight) {
                const railRightEdgePx = railRightPositionPx + railWidth;
                arrowRight.style.width = `${dangerousZoneRightPx - railRightEdgePx}px`;
                arrowRight.style.left = `${railRightEdgePx}px`;
                arrowRight.querySelector('.measurement-text').textContent = formattedDistance + ' m';
            }
        }
        function updateGarageSchemaWidths() {
            const activeSchema = document.querySelector('.garage-schema.active');
            if (!activeSchema) return;
            const sceneWidth = activeSchema.offsetWidth;
            const baseRailWidth = 0.022 * sceneWidth;
            const baseTrackWidth = 0.078 * sceneWidth;
            const trainWidth = 0.066 * sceneWidth;
            const minVisualDistance = 0.22 * sceneWidth;
            const maxVisualDistance = 0.35 * sceneWidth;
            const minDistance = 1.25;
            const maxDistance = 2.30;

            function createZone(className, left, width) {
                const zone = document.createElement('div');
                zone.className = `schema-element ${className}`;
                zone.style.left = `${left}px`;
                zone.style.width = `${width}px`;
                return zone;
            }
            function createArrow(left, width, text) {
                const arrow = document.createElement('div');
                arrow.className = 'measurement-arrow';
                arrow.style.left = `${left}px`;
                arrow.style.width = `${width}px`;
                arrow.innerHTML = `<span class="measurement-text">${text}</span>`;
                return arrow;
            }

            if (activeSchema.id === 'garage-accotement-schema') {
                const defaultZoneDistance = 1.50;
                const visualDistance = minVisualDistance + ((defaultZoneDistance - minDistance) / (maxDistance - minDistance)) * (maxVisualDistance - minVisualDistance);
                const totalDangerousZoneWidth = baseTrackWidth + (2 * visualDistance);
                const garageVisualWidth = 0.15 * sceneWidth;
                const center = sceneWidth / 2;
                const dangerousZoneLeft = center - (totalDangerousZoneWidth / 2);
                const dangerousZoneRight = center + (totalDangerousZoneWidth / 2);

                document.getElementById('accotement-dangerous-zone').style.width = `${totalDangerousZoneWidth}px`;
                document.getElementById('accotement-dangerous-zone').style.left = `${dangerousZoneLeft}px`;
                document.getElementById('accotement-garage-zone-left').style.width = `${garageVisualWidth}px`;
                document.getElementById('accotement-garage-zone-left').style.left = `${dangerousZoneLeft - garageVisualWidth}px`;
                document.getElementById('accotement-garage-zone-right').style.width = `${garageVisualWidth}px`;
                document.getElementById('accotement-garage-zone-right').style.left = `${dangerousZoneRight}px`;
                const railLeftPositionPx = sceneWidth * 0.45;
                const railRightPositionPx = sceneWidth * 0.528;
                const railRightEdgePx = railRightPositionPx + baseRailWidth;
                document.getElementById('accotement-danger-arrow-left').style.width = `${railLeftPositionPx - dangerousZoneLeft}px`;
                document.getElementById('accotement-danger-arrow-left').style.left = `${dangerousZoneLeft}px`;
                document.getElementById('accotement-danger-arrow-right').style.width = `${dangerousZoneRight - railRightEdgePx}px`;
                document.getElementById('accotement-danger-arrow-right').style.left = `${railRightEdgePx}px`;
                
                const accotementZdText = document.getElementById('accotement-zd-text');
                const garageTextLeft = document.getElementById('garage-text-left');
                const garageTextRight = document.getElementById('garage-text-right');
                
                accotementZdText.style.left = `${dangerousZoneLeft + (totalDangerousZoneWidth / 2)}px`;
                garageTextLeft.style.left = `${dangerousZoneLeft - (garageVisualWidth / 2)}px`;
                garageTextRight.style.left = `${dangerousZoneRight + (garageVisualWidth / 2)}px`;
                
                document.getElementById('accotement-garage-arrow-left').style.width = `${garageVisualWidth}px`;
                document.getElementById('accotement-garage-arrow-left').style.left = `${dangerousZoneLeft - garageVisualWidth}px`;
                document.getElementById('accotement-garage-arrow-right').style.width = `${garageVisualWidth}px`;
                document.getElementById('accotement-garage-arrow-right').style.left = `${dangerousZoneRight}px`;
                const accotementTrain = document.getElementById('accotement-train');
                accotementTrain.style.left = `calc(50% - ${trainWidth / 2}px)`;

                // Add traverses to the accotement schema
                const accotementTraversesContainer = activeSchema.querySelector('.traverses-container');
                createTraverses(accotementTraversesContainer);

            } else if (activeSchema.id === 'garage-entrevoie-schema') {
                activeSchema.innerHTML = '';
                const newZdDistanceLeft = 2.00;
                const newZdDistanceRight = 1.50;
                const garageDistance = 0.70;
                const visualZDLeft = minVisualDistance + ((newZdDistanceLeft - minDistance) / (maxDistance - minDistance)) * (maxVisualDistance - minVisualDistance);
                const visualZDRight = minVisualDistance + ((newZdDistanceRight - minDistance) / (maxDistance - minDistance)) * (maxVisualDistance - minVisualDistance);
                const visualGarage = minVisualDistance + ((garageDistance - minDistance) / (maxDistance - minDistance)) * (maxVisualDistance - minVisualDistance);

                // Calculate element widths relative to the container for better responsiveness
                const railWidth = 0.015 * sceneWidth;
                const trackWidth = 0.05 * sceneWidth;
                const trainWidth = 0.066 * sceneWidth;

                // Total width of the entire schema to be centered
                const totalSchemaWidth = visualZDLeft + visualGarage + visualZDRight + (2 * (railWidth + trackWidth + railWidth));

                // Calculate starting position to center the schema
                const startX = (sceneWidth - totalSchemaWidth) / 2;

                // Define positions
                const railLeft1Pos = startX;
                const railLeft2Pos = railLeft1Pos + railWidth + trackWidth;
                const zd2_00Left = railLeft2Pos + railWidth;
                const garageZoneLeft = zd2_00Left + visualZDLeft;
                const zd1_50Left = garageZoneLeft + visualGarage;
                const railRight1Pos = zd1_50Left + visualZDRight;
                const railRight2Pos = railRight1Pos + railWidth + trackWidth;

                // Ajout des zones
                const zd2_00 = createZone('dangerous-zone', zd2_00Left, visualZDLeft);
                zd2_00.innerHTML = '<div class="danger-line left"></div><div class="danger-line right"></div>';
                const garageZone = createZone('safe-zone', garageZoneLeft, visualGarage);
                garageZone.innerHTML = '<div class="safe-line left"></div><div class="safe-line right"></div>';
                const zd1_50 = createZone('dangerous-zone', zd1_50Left, visualZDRight);
                zd1_50.innerHTML = '<div class="danger-line left"></div><div class="danger-line right"></div>';

                activeSchema.appendChild(zd2_00);
                activeSchema.appendChild(garageZone);
                activeSchema.appendChild(zd1_50);

                // Ajout des rails et traverses
                const railLeft1 = createZone('rail', railLeft1Pos, railWidth);
                const railLeft2 = createZone('rail', railLeft2Pos, railWidth);
                const railLeftTraverses = createZone('traverses-container', railLeft1Pos + railWidth, trackWidth);
                createTraverses(railLeftTraverses, 10);
                activeSchema.appendChild(railLeft1);
                activeSchema.appendChild(railLeft2);
                activeSchema.appendChild(railLeftTraverses);

                const railRight1 = createZone('rail', railRight1Pos, railWidth);
                const railRight2 = createZone('rail', railRight2Pos, railWidth);
                const railRightTraverses = createZone('traverses-container', railRight1Pos + railWidth, trackWidth);
                createTraverses(railRightTraverses, 10);
                activeSchema.appendChild(railRight1);
                activeSchema.appendChild(railRight2);
                activeSchema.appendChild(railRightTraverses);

                // Ajout des trains
                const trainLeft = document.createElement('div');
                trainLeft.className = 'train entrevoie-train-left';
                trainLeft.style.left = `${railLeft1Pos + railWidth + (trackWidth / 2) - (trainWidth / 2)}px`;
                trainLeft.innerHTML = `<div class="train-windows"><div class="train-window"></div><div class="train-window"></div><div class="train-window"></div></div>`;
                activeSchema.appendChild(trainLeft);
                
                const trainRight = document.createElement('div');
                trainRight.className = 'train entrevoie-train-right';
                trainRight.style.left = `${railRight1Pos + railWidth + (trackWidth / 2) - (trainWidth / 2)}px`;
                trainRight.innerHTML = `<div class="train-windows"><div class="train-window"></div><div class="train-window"></div><div class="train-window"></div></div>`;
                activeSchema.appendChild(trainRight);

                // Ajout des textes
                const zdText1 = document.createElement('div');
                zdText1.className = 'zd-text'; zdText1.innerHTML = '<span class="full-text">ZONE DANGEREUSE</span><span class="abbr-text">ZD</span>'; zdText1.style.left = `${zd2_00Left + visualZDLeft / 2}px`; activeSchema.appendChild(zdText1);
                const garageText = document.createElement('div');
                garageText.className = 'garage-text'; garageText.textContent = 'GARAGE'; garageText.style.left = `${garageZoneLeft + visualGarage / 2}px`; activeSchema.appendChild(garageText);
                const zdText2 = document.createElement('div');
                zdText2.className = 'zd-text'; zdText2.innerHTML = '<span class="full-text">ZONE DANGEREUSE</span><span class="abbr-text">ZD</span>'; zdText2.style.left = `${zd1_50Left + visualZDRight / 2}px`; activeSchema.appendChild(zdText2);

                // Ajout des flèches
                activeSchema.appendChild(createArrow(zd2_00Left, visualZDLeft, `${newZdDistanceLeft.toFixed(2).replace('.', ',')} m`));
                activeSchema.appendChild(createArrow(garageZoneLeft, visualGarage, `0,70 m`));
                activeSchema.appendChild(createArrow(zd1_50Left, visualZDRight, `${newZdDistanceRight.toFixed(2).replace('.', ',')} m`));

            } else if (activeSchema.id === 'garage-voie-interdite-schema') {
                activeSchema.innerHTML = '';
                const voie1Left = 0.15 * sceneWidth;
                const voie2Left = 0.65 * sceneWidth;
                const voie2Right = voie2Left + baseRailWidth + baseTrackWidth + baseRailWidth;
                
                const rail1_1 = document.createElement('div'); rail1_1.className = 'rail'; rail1_1.style.left = `${voie1Left}px`;
                activeSchema.appendChild(rail1_1);
                const rail1_2 = document.createElement('div'); rail1_2.className = 'rail'; rail1_2.style.left = `${voie1Left + baseRailWidth + baseTrackWidth}px`; activeSchema.appendChild(rail1_2);
                const traverses1 = createZone('traverses-container', voie1Left + baseRailWidth, baseTrackWidth);
                createTraverses(traverses1);
                activeSchema.appendChild(traverses1);
                
                const train1 = document.createElement('div');
                train1.className = 'train';
                train1.style.left = `${voie1Left + baseRailWidth + (baseTrackWidth / 2) - (trainWidth / 2)}px`;
                train1.innerHTML = `<div class="train-windows"><div class="train-window"></div><div class="train-window"></div><div class="train-window"></div></div>`;
                activeSchema.appendChild(train1);
                
                const rail2_1 = document.createElement('div'); rail2_1.className = 'rail'; rail2_1.style.left = `${voie2Left}px`; activeSchema.appendChild(rail2_1);
                const rail2_2 = document.createElement('div'); rail2_2.className = 'rail';
                rail2_2.style.left = `${voie2Left + baseRailWidth + baseTrackWidth}px`; activeSchema.appendChild(rail2_2);
                const traverses2 = createZone('traverses-container', voie2Left + baseRailWidth, baseTrackWidth);
                createTraverses(traverses2);
                activeSchema.appendChild(traverses2);
                
                const samSign = document.createElement('div');
                samSign.className = 'sam-sign';
                samSign.textContent = 'SAM';
                samSign.style.left = `${voie2Left + baseRailWidth + (baseTrackWidth / 2)}px`;
                samSign.style.transform = `translateX(-50%) translateY(-50%)`;
                activeSchema.appendChild(samSign);
                const voieInterditeTextContainer = document.createElement('div');
                voieInterditeTextContainer.className = 'voie-interdite-text-container';
                voieInterditeTextContainer.innerHTML = `Voie Interdite`;
                activeSchema.appendChild(voieInterditeTextContainer);
                
                const zd = document.createElement('div');
                zd.className = 'dangerous-zone'; zd.style.left = `${voie1Left + baseRailWidth + baseTrackWidth + baseRailWidth}px`;
                zd.style.width = `${voie2Left - (voie1Left + baseRailWidth + baseTrackWidth + baseRailWidth)}px`; activeSchema.appendChild(zd);
                const garage = document.createElement('div'); garage.className = 'safe-zone';
                garage.style.left = `${voie2Left}px`; garage.style.width = `${voie2Right - voie2Left}px`; activeSchema.appendChild(garage);
                
                const zdText = document.createElement('div'); zdText.className = 'zd-text';
                zdText.innerHTML = '<span class="full-text">ZONE DANGEREUSE</span><span class="abbr-text">ZD</span>'; zdText.style.left = `${zd.offsetLeft + zd.offsetWidth / 2}px`; activeSchema.appendChild(zdText);
                const garageText = document.createElement('div');
                garageText.className = 'garage-text'; garageText.textContent = 'GARAGE'; garageText.style.left = `${garage.offsetLeft + garage.offsetWidth / 2}px`; activeSchema.appendChild(garageText);
            }
        }
        function showGarageSchema(type) {
            garageSchemaElements.forEach(schema => {
                schema.classList.remove('active');
            });
            const schemaToShow = document.getElementById(`garage-${type}-schema`);
            if (schemaToShow) {
                schemaToShow.classList.add('active');
                updateGarageSchemaWidths();
            }
            // Update button highlights
            garageButtons.forEach(button => {
                button.classList.remove('active-button');
            });
            document.getElementById(`garage-${type}`).classList.add('active-button');
        }
        
        speedSlider.addEventListener('input', (e) => {
            const speed = parseInt(e.target.value);
            speedValue.textContent = speed + ' km/h';
            updateZoneWidth(speed);
            
            // Remove highlight from all headers and cells
            speedHeaders.forEach(header => header.classList.remove('highlight'));
            speedCells.forEach(cell => cell.classList.remove('highlight'));
            
            // Add highlight to the corresponding header and cell
            const distanceObj = distances.find(d => speed <= d.speed) || distances[distances.length - 1];
            const correspondingHeader = document.querySelector(`.speed-header[data-speed="${distanceObj.speed}"]`);
            const correspondingCell = document.querySelector(`.speed-cell[data-speed="${distanceObj.speed}"]`);
            if (correspondingHeader) correspondingHeader.classList.add('highlight');
            if (correspondingCell) correspondingCell.classList.add('highlight');
        });
        
        // Function to handle speed selection from both headers and cells
        function handleSpeedSelection(element) {
            const speed = parseInt(element.dataset.speed);
            const rangeText = element.dataset.range;
            
            speedSlider.value = speed;
            speedValue.textContent = rangeText;
            updateZoneWidth(speed);

            // Remove highlight from all headers and cells
            speedHeaders.forEach(h => h.classList.remove('highlight'));
            speedCells.forEach(c => c.classList.remove('highlight'));
            
            // Add highlight to the clicked element and its corresponding pair
            if (element.classList.contains('speed-header')) {
                element.classList.add('highlight');
                // Find corresponding cell
                const correspondingCell = document.querySelector(`.speed-cell[data-speed="${speed}"]`);
                if (correspondingCell) {
                    correspondingCell.classList.add('highlight');
                }
            } else if (element.classList.contains('speed-cell')) {
                element.classList.add('highlight');
                // Find corresponding header
                const correspondingHeader = document.querySelector(`.speed-header[data-speed="${speed}"]`);
                if (correspondingHeader) {
                    correspondingHeader.classList.add('highlight');
                }
            }
        }

        speedHeaders.forEach(header => {
            header.addEventListener('click', () => handleSpeedSelection(header));
        });

        speedCells.forEach(cell => {
            cell.addEventListener('click', () => handleSpeedSelection(cell));
        });
        
        actionSelect.addEventListener('change', updateDVN);
        actionSelect.addEventListener('focus', () => {
          Array.from(actionSelect.options).forEach(option => {
            option.textContent = option.dataset.fullText;
          });
        });
        actionSelect.addEventListener('blur', () => {
          Array.from(actionSelect.options).forEach(option => {
            option.textContent = option.dataset.shortText;
          });
        });
        
        speedSelect.addEventListener('change', updateDVN);
        
        window.addEventListener('load', () => {
            const defaultSpeed = parseInt(speedSlider.value);
            const defaultDistanceObj = distances.find(d => defaultSpeed <= d.speed) || distances[distances.length - 1];
            speedValue.textContent = defaultDistanceObj.range;
            updateZoneWidth(defaultSpeed);
            showGarageSchema('accotement');
            updateDVN();
            createTraverses(document.querySelector('.scene .traverses-container'));
            
            // Initial highlight for default speed
            const defaultHeader = document.querySelector(`.speed-header[data-speed="${defaultDistanceObj.speed}"]`);
            const defaultCell = document.querySelector(`.speed-cell[data-speed="${defaultDistanceObj.speed}"]`);
            if (defaultHeader) defaultHeader.classList.add('highlight');
            if (defaultCell) defaultCell.classList.add('highlight');
        });
        window.addEventListener('resize', () => {
            updateGarageSchemaWidths();
            updateZoneWidth(speedSlider.value);
            createTraverses(document.querySelector('.scene .traverses-container'));
        });
        
        garageAccotementBtn.addEventListener('click', () => showGarageSchema('accotement'));
        garageEntrevoieBtn.addEventListener('click', () => showGarageSchema('entrevoie'));
        garageVoieInterditeBtn.addEventListener('click', () => showGarageSchema('voie-interdite'));
    </script>
</body>
</html>
